# Find the third highest in a list (find highest,second highest,third highest number )


a = [10,20,45,1,3,46,62,34,72,67]

max = a[0]
smax = a[1]
tmax = a[2]

for i in a:
    if i > max:
        tmax=smax
        smax  = max
        max = i
    elif i > smax and i != max:
        tmax =  smax
        smax = i
    elif i >tmax and i !=smax:
        tmax = i
         
print("max: ",max)
print("second max: ",smax)
print("third max: ",tmax)



# Q: Check the number is palindrome or not ?


number=1001
t=number

reverse = 0

while number >0:
    digit = number%10
    reverse =  reverse*10 +digit
    number =  number//10
    


if(reverse == t):
    print("Number is palindrome")
else:
    print("Number is not palindrome")

